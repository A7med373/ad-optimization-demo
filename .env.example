APP_NAME=Ad Optimization Demo
ENVIRONMENT=local
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/ad_optimization
REDIS_URL=redis://redis:6379/0
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_CLICKS=ad.clicks
KAFKA_TOPIC_ORDERS=marketplace.orders
ATTRIBUTION_WINDOW_HOURS=72
MATCH_THRESHOLD=0.60
YANDEX_METRIKA_COUNTER_ID=demo-counter
YANDEX_METRIKA_TOKEN=demo-token

